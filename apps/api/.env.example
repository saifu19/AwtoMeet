PORT=3001
NODE_ENV=development

# Database
MYSQL_URL=mysql://root:root@localhost:3306/meeting_app
# Tests use a separate database (configured in vitest.config.ts)
# Create it: mysql -u root -e "CREATE DATABASE IF NOT EXISTS meeting_app_test;"
# Sync schema: MYSQL_URL=mysql://root:root@localhost:3306/meeting_app_test npx drizzle-kit push

# Auth
JWT_SECRET=replace_me_with_openssl_rand_hex_32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v0/auth/google/callback

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Email (SMTP — works with Mailgun, SendGrid, or any SMTP provider)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MojoMeet <noreply@yourdomain.com>

# Internal API (worker → API communication)
INTERNAL_API_KEY=replace_me_with_openssl_rand_hex_32

# Frontend
WEB_URL=http://localhost:5173

# Cross-site cookies — set to "true" ONLY when web and api live on different
# registrable domains (e.g. *.vercel.app web + *.on-forge.com api). Flips the
# refresh and stream_session cookies to SameSite=None; Secure so browsers will
# send them on cross-site XHR. Leave unset/empty for local dev and for deploys
# where web + api share an eTLD+1 (e.g. app.mydomain.com + api.mydomain.com).
CROSS_SITE_COOKIES=
