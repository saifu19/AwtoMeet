# In development with Vite proxy: leave empty (proxy forwards /auth/* to API)
# In production: set to the actual API URL (e.g., https://api.awtomeet.app)
VITE_API_URL=

# Set to "true" to enable MSW mock handlers (when M10 API is not running)
VITE_ENABLE_MSW=false

# API server target for Vite dev proxy (server-side only, not shipped to browser)
API_TARGET=http://127.0.0.1:3001
